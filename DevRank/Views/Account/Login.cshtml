@model DevRank.Models.LoginViewModel

@{
    ViewBag.Title = "Login";
}

<section class="page-section narrow">
    <div class="section-heading">
        <span class="eyebrow">Acesso rápido</span>
        <h1>Entrar na arena</h1>
        <p>Use um usuário fake existente ou crie um novo desafiante.</p>
    </div>

    <form class="form-panel" method="post" action="@Url.Action("Login", "Account")">
        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert-box">@Model.ErrorMessage</div>
        }

        <label>
            Usuário
            <input type="text" name="Username" value="@Model.Username" placeholder="ana" autofocus />
        </label>

        <label>
            Senha
            <input type="password" name="Password" placeholder="123" />
        </label>

        <label class="check-option">
            <input type="checkbox" name="RememberMe" value="true" @(Model.RememberMe ? "checked" : "") />
            <span>Manter conectado neste dispositivo</span>
        </label>

        <button class="btn btn-primary" type="submit">Entrar</button>
        <a class="inline-link" href="@Url.Action("Register", "Account")">Criar novo programador</a>
    </form>
</section>
