@model DevRank.Models.HomeViewModel

@{
    ViewBag.Title = "Descubra seu nível real";
}

<section class="premium-hero">
    <div class="hero-signal">
        <span class="live-dot"></span>
        <span>2.418 devs calibrando reputação técnica nesta season</span>
    </div>
    <div class="premium-hero-grid">
        <div class="premium-hero-copy">
            <span class="eyebrow">Developer reputation arena</span>
            <h1>Descubra seu nível como desenvolvedor.</h1>
            <p>
                DevRank avalia prática, comunicação, arquitetura, debugging e maturidade sob pressão.
                Não é quiz. Não é prova decorada. É uma arena para provar engenharia no mundo real.
            </p>
            <div class="hero-actions">
                <a class="btn btn-primary" href="@Url.Action("Register", "Account")">Criar perfil técnico</a>
                <a class="btn btn-secondary" href="@Url.Action("Index", "Leaderboard")">Ver ranking mundial</a>
            </div>
            <div class="hero-proof">
                <div>
                    <strong>91%</strong>
                    <span>sentem mais confianca em entrevistas</span>
                </div>
                <div>
                    <strong>14k</strong>
                    <span>desafios praticos simulados</span>
                </div>
                <div>
                    <strong>38</strong>
                    <span>empresas observando talentos</span>
                </div>
            </div>
        </div>

        <aside class="hero-console" aria-label="Preview da arena">
            <div class="console-top">
                <span>Live assessment</span>
                <strong>Production Incident #42</strong>
            </div>
            <div class="console-code">
                <span>01</span><p>API em producao com latencia alta.</p>
                <span>02</span><p>Explique diagnóstico, mitigação e comunicação.</p>
                <span>03</span><p>Avaliando clareza, critério e pressão...</p>
            </div>
            <div class="console-score">
                <div>
                    <small>Score técnico</small>
                    <strong>87</strong>
                </div>
                <div>
                    <small>Comunicação</small>
                    <strong>79</strong>
                </div>
                <div>
                    <small>Elo ganho</small>
                    <strong class="delta-positive">+24</strong>
                </div>
            </div>
        </aside>
    </div>
</section>

<section class="observer-strip" aria-label="Empresas fake observando talentos">
    <span>Talentos observados por times fake de</span>
    <strong>Tornfy Labs</strong>
    <strong>Northwind</strong>
    <strong>Contoso Cloud</strong>
    <strong>Arcadia Systems</strong>
    <strong>PixelForge</strong>
</section>

<section class="arena-story">
    <div class="section-heading">
        <span class="eyebrow">Por que isso existe?</span>
        <h2>Porque muita gente boa trava quando precisa provar valor.</h2>
        <p>
            Desenvolvedores reais resolvem problemas reais, mas entrevistas ainda confundem memoria,
            nervosismo e performance. DevRank cria um ambiente progressivo para treinar, competir e
            construir reputação técnica com contexto.
        </p>
    </div>
    <div class="story-grid">
        <article>
            <span>01</span>
            <h3>Treine entrevistas reais</h3>
            <p>Perguntas técnicas, emocionais e arquiteturais com pressão simulada.</p>
        </article>
        <article>
            <span>02</span>
            <h3>Resolva cenarios de mercado</h3>
            <p>Incidentes, legado, PR review, conflitos, performance e comunicação com cliente.</p>
        </article>
        <article>
            <span>03</span>
            <h3>Construa reputação</h3>
            <p>Perfil público, Elo por skill, conquistas, histórico e sinais para recrutadores.</p>
        </article>
    </div>
</section>

<section class="live-board-section">
    <div class="section-heading split-heading">
        <div>
            <span class="eyebrow">Ranking ao vivo fake</span>
            <h2>O mercado observa quem evolui.</h2>
        </div>
        <a class="btn btn-secondary" href="@Url.Action("Index", "Leaderboard")">Leaderboard completo</a>
    </div>
    <div class="live-layout">
        <div class="leaderboard premium-board">
            @for (var index = 0; index < Model.TopProgrammers.Count; index++)
            {
                var programmer = Model.TopProgrammers[index];
                var avatarUrl = programmer.FakePhotoUrl;
                var hasCustomAvatar = !string.IsNullOrWhiteSpace(avatarUrl) && (avatarUrl.StartsWith("data:") || avatarUrl.StartsWith("~/"));
                var avatarStyleUrl = hasCustomAvatar && avatarUrl.StartsWith("~/") ? Url.Content(avatarUrl) : avatarUrl;
                <a class="leader-row" href="@Url.Action("Public", "Profile", new { username = programmer.Username })">
                    <div class="position">#@(index + 1)</div>
                    <div class="fake-avatar mini @(hasCustomAvatar ? "has-photo" : "")">
                        @if (hasCustomAvatar)
                        {
                            <img src="@avatarStyleUrl" alt="Foto de @programmer.Name" />
                        }
                        else
                        {
                            @programmer.Name.Substring(0, 1)
                        }
                    </div>
                    <div class="player">
                        <strong>@programmer.Name</strong>
                        <span>@programmer.MainStack</span>
                    </div>
                    <div class="rank-pill rank-@programmer.Level.ToLower()">@programmer.Level</div>
                    <div class="elo">@programmer.EloRating Elo</div>
                </a>
            }
        </div>
        <aside class="public-preview-card">
            <span class="eyebrow">Perfil público</span>
            <h3>Uma identidade técnica para compartilhar.</h3>
            <p>Mostre stack, badges, evolução, comunicação, áreas fortes e ranking. O dev sente orgulho. O recrutador entende contexto.</p>
            <a class="btn btn-primary" href="@Url.Action("Public", "Profile", new { username = Model.TopProgrammers[0].Username })">Ver preview público</a>
        </aside>
    </div>
</section>

<section class="differentiator-section">
    <div class="section-heading">
        <span class="eyebrow">Não é mais uma plataforma de teste</span>
        <h2>DevRank mede o que aparece quando o código encontra pressão.</h2>
    </div>
    <div class="compare-grid">
        <article>
            <h3>Teste comum</h3>
            <p>Quiz, algoritmo isolado, resposta decorada, pouca leitura de maturidade.</p>
        </article>
        <article class="featured">
            <h3>DevRank</h3>
            <p>Cenários reais, explicação de decisões, pressão simulada, Elo vivo e perfil público.</p>
        </article>
        <article>
            <h3>Entrevista tradicional</h3>
            <p>Subjetiva, difícil de comparar e dependente do humor do dia.</p>
        </article>
    </div>
</section>

<section class="timeline-section">
    <div class="section-heading">
        <span class="eyebrow">Evolução progressiva</span>
        <h2>De medo de entrevista para reputação técnica.</h2>
    </div>
    <div class="timeline-track">
        <article>
            <span class="timeline-label">Semana 1</span>
            <strong>Diagnóstico real</strong>
            <p>Mapeie lacunas técnicas e comportamentais.</p>
        </article>
        <article>
            <span class="timeline-label">Semana 2</span>
            <strong>Treino sem punição</strong>
            <p>Ganhe clareza antes de competir por Elo.</p>
        </article>
        <article>
            <span class="timeline-label">Semana 3</span>
            <strong>Arena ranqueada</strong>
            <p>Resolva desafios sob pressão simulada.</p>
        </article>
        <article>
            <span class="timeline-label">Semana 4</span>
            <strong>Perfil público</strong>
            <p>Compartilhe sua evolução com orgulho.</p>
        </article>
    </div>
</section>

<section class="testimonial-section">
    <div class="testimonial-card">
        <p>"Pela primeira vez um teste técnico pareceu trabalho real, não pegadinha. O feedback me ajudou a explicar melhor minhas decisões."</p>
        <strong>Marina Lopes</strong>
        <span>Backend Developer / Perfil fake</span>
    </div>
    <div class="testimonial-card">
        <p>"Como recrutador, eu olharia esse ranking antes de chamar alguém. Ele mostra evolução, não só currículo bonito."</p>
        <strong>Rafael Torres</strong>
        <span>Tech Recruiter / Depoimento fake</span>
    </div>
</section>

<section class="final-cta premium-final">
    <span class="eyebrow">A arena esta aberta</span>
    <h2>Crie seu perfil, resolva um desafio e descubra onde voce realmente esta.</h2>
    <div class="hero-actions center">
        <a class="btn btn-primary" href="@Url.Action("Register", "Account")">Entrar agora</a>
        <a class="btn btn-secondary" href="@Url.Action("Index", "Challenge")">Explorar desafios</a>
    </div>
</section>
