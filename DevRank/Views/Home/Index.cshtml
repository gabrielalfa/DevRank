@model DevRank.Models.HomeViewModel

@{
    ViewBag.Title = "Arena de Ranking para Devs";
}

<section class="hero-section">
    <div class="hero-copy">
        <span class="eyebrow">Hiring signal / Dev assessment arena</span>
        <h1>Ranking tecnico para separar discurso de pratica.</h1>
        <p>
            DevRank transforma desafios reais de engenharia em partidas ranqueadas.
            Em vez de confiar apenas em curriculo, entrevista subjetiva ou teste teorico,
            voce acompanha performance pratica, evolucao de Elo e historico tecnico.
        </p>
        <div class="hero-actions">
            <a class="btn btn-primary" href="@Url.Action("Index", "Challenge")">Entrar na Arena</a>
            <a class="btn btn-secondary" href="#plans">Ver planos</a>
        </div>
        <div class="trust-strip" aria-label="Casos de uso">
            <span>Triagem tecnica</span>
            <span>Treinamento interno</span>
            <span>Ranking de squads</span>
        </div>
    </div>

    <aside class="arena-card" aria-label="Resumo competitivo">
        <div class="arena-glow"></div>
        <div class="rank-badge">Diamante</div>
        <div class="rating-display">2310</div>
        <p>Elo atual do lider</p>
        <div class="mini-grid">
            <div>
                <strong>@Model.TotalDevelopers</strong>
                <span>devs</span>
            </div>
            <div>
                <strong>@Model.TotalChallenges</strong>
                <span>desafios</span>
            </div>
            <div>
                <strong>@Model.TotalMatches</strong>
                <span>partidas</span>
            </div>
        </div>
    </aside>
</section>

<section class="proof-section" aria-label="Por que usar">
    <div class="section-heading">
        <span class="eyebrow">Problema que resolve</span>
        <h2>Entrevista tecnica ainda mede muito teatro.</h2>
        <p>
            Bons devs nem sempre brilham em conversa cronometrada. E candidatos confiantes
            nem sempre sustentam uma decisao tecnica quando o codigo aperta.
        </p>
    </div>
    <div class="proof-grid">
        <article>
            <strong>Menos achismo</strong>
            <p>Historico de partidas, Elo e feedback tecnico criam um sinal comparavel entre pessoas.</p>
        </article>
        <article>
            <strong>Mais contexto real</strong>
            <p>Desafios de MVC, performance, concorrencia e legado simulam decisoes do dia a dia.</p>
        </article>
        <article>
            <strong>Melhor evolucao</strong>
            <p>O ranking mostra progresso ao longo do tempo, nao apenas um teste isolado.</p>
        </article>
    </div>
</section>

<section class="value-section" aria-label="Como funciona">
    <article>
        <span>01</span>
        <h2>Escolha um desafio</h2>
        <p>Casos curtos de engenharia: endpoint MVC, performance, service mal dividido ou bug dificil.</p>
    </article>
    <article>
        <span>02</span>
        <h2>Envie a solucao</h2>
        <p>Um editor simples recebe sua proposta. Para o MVP, a avaliacao sera fake e controlada.</p>
    </article>
    <article>
        <span>03</span>
        <h2>Suba no Elo</h2>
        <p>Vitorias aumentam rating, derrotas ensinam. Bronze, Prata, Ouro, Platina e Diamante.</p>
    </article>
</section>

<section class="conviction-section" aria-label="Beneficios da plataforma">
    <div class="conviction-copy">
        <span class="eyebrow">Para times e devs</span>
        <h2>Uma camada competitiva para desenvolvimento profissional.</h2>
        <p>
            Use o DevRank para simular entrevistas, calibrar senioridade, treinar tomada de decisao
            e criar uma cultura de melhoria continua sem montar um processo pesado.
        </p>
    </div>
    <div class="benefit-list">
        <div>
            <span>01</span>
            <strong>Contratacao com evidencias</strong>
            <p>Compare candidatos por desempenho pratico em problemas equivalentes.</p>
        </div>
        <div>
            <span>02</span>
            <strong>Treino continuo</strong>
            <p>Transforme refatoracao, revisao e performance em desafios curtos e repetiveis.</p>
        </div>
        <div>
            <span>03</span>
            <strong>Gamificacao saudavel</strong>
            <p>Elo, ranks e badges dao clareza de evolucao sem precisar de processo enterprise.</p>
        </div>
    </div>
</section>

<section id="plans" class="plans-section" aria-label="Planos">
    <div class="section-heading">
        <span class="eyebrow">Planos para validar mercado</span>
        <h2>Comece pequeno, prove valor, escale depois.</h2>
    </div>

    <div class="plans-grid">
        <article class="plan-card">
            <span class="plan-label">Solo</span>
            <h3>Dev Arena</h3>
            <p class="price">R$ 0</p>
            <p>Para devs testarem habilidades e montarem historico publico.</p>
            <ul>
                <li>Desafios fake do MVP</li>
                <li>Perfil com Elo e badges</li>
                <li>Historico de partidas</li>
            </ul>
            <a class="btn btn-secondary" href="@Url.Action("Register", "Account")">Criar perfil</a>
        </article>

        <article class="plan-card featured">
            <span class="plan-label">Validacao</span>
            <h3>Team Trial</h3>
            <p class="price">R$ 99</p>
            <p>Para pequenas equipes validarem ranking tecnico interno.</p>
            <ul>
                <li>Leaderboard por time</li>
                <li>Desafios por categoria</li>
                <li>Feedback tecnico simulado</li>
            </ul>
            <a class="btn btn-primary" href="@Url.Action("Index", "Challenge")">Testar agora</a>
        </article>

        <article class="plan-card">
            <span class="plan-label">Empresas</span>
            <h3>Hiring Lab</h3>
            <p class="price">Sob consulta</p>
            <p>Para recrutamento tecnico com trilhas por stack e senioridade.</p>
            <ul>
                <li>Rankings privados</li>
                <li>Relatorios por candidato</li>
                <li>Desafios customizados</li>
            </ul>
            <a class="btn btn-secondary" href="@Url.Action("Index", "Leaderboard")">Ver ranking</a>
        </article>
    </div>
</section>

<section id="ranking" class="leaderboard-section">
    <div class="section-heading">
        <span class="eyebrow">Leaderboard inicial</span>
        <h2>Melhores programadores</h2>
    </div>

    <div class="leaderboard">
        @for (var index = 0; index < Model.TopProgrammers.Count; index++)
        {
            var programmer = Model.TopProgrammers[index];
            <article class="leader-row">
                <div class="position">#@(index + 1)</div>
                <div class="player">
                    <strong>@programmer.Name</strong>
                    <span>@programmer.MainStack</span>
                </div>
                <div class="rank-pill rank-@programmer.Level.ToLower()">@programmer.Level</div>
                <div class="elo">@programmer.EloRating Elo</div>
                <div class="winrate">@programmer.WinRate% WR</div>
            </article>
        }
    </div>
</section>

<section class="final-cta" aria-label="Chamada final">
    <span class="eyebrow">MVP pronto para testar</span>
    <h2>Entre, resolva um desafio e veja seu Elo mudar.</h2>
    <div class="hero-actions center">
        <a class="btn btn-primary" href="@Url.Action("Index", "Challenge")">Entrar na Arena</a>
        <a class="btn btn-secondary" href="@Url.Action("Register", "Account")">Criar programador</a>
    </div>
</section>
