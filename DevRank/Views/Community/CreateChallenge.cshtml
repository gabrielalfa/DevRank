@model DevRank.Models.CommunityCreateChallengeViewModel

@{
    ViewBag.Title = "Criar desafio comunitário";
    var selectedType = string.IsNullOrWhiteSpace(Model.Type) ? "Cenário real" : Model.Type;
    var selectedCategory = string.IsNullOrWhiteSpace(Model.Category) ? "Backend" : Model.Category;
}

<section class="community-form-page">
    <div class="section-heading split-heading">
        <div>
            <span class="eyebrow">Criar contribuição</span>
            <h1>Novo desafio comunitário</h1>
            <p>Contribuições boas parecem trabalho real: contexto, pressão, critérios e resposta esperada.</p>
        </div>
        <a class="btn btn-secondary" href="@Url.Action("Index", "Community")">Voltar ao Hub</a>
    </div>

    <form class="community-create-layout" method="post" action="@Url.Action("CreateChallenge", "Community")">
        <div class="community-panel community-form">
            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="alert-box">@Model.ErrorMessage</div>
            }
            @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
            {
                <div class="success-box">@Model.SuccessMessage</div>
            }

            <label>
                Título
                <input type="text" name="Title" value="@Model.Title" placeholder="Ex: Incidente de API com timeout intermitente" />
            </label>

            <div class="form-grid two">
                <label>
                    Tipo
                    <select name="Type">
                        <option @(selectedType == "Cenário real" ? "selected" : "")>Cenário real</option>
                        <option @(selectedType == "Desafio técnico" ? "selected" : "")>Desafio técnico</option>
                        <option @(selectedType == "Entrevista" ? "selected" : "")>Entrevista</option>
                        <option @(selectedType == "Review de código" ? "selected" : "")>Review de código</option>
                        <option @(selectedType == "Comportamental" ? "selected" : "")>Comportamental</option>
                    </select>
                </label>
                <label>
                    Categoria
                    <select name="Category">
                        <option @(selectedCategory == "Backend" ? "selected" : "")>Backend</option>
                        <option @(selectedCategory == "Frontend" ? "selected" : "")>Frontend</option>
                        <option @(selectedCategory == "Arquitetura" ? "selected" : "")>Arquitetura</option>
                        <option @(selectedCategory == "SQL" ? "selected" : "")>SQL</option>
                        <option @(selectedCategory == "DevOps" ? "selected" : "")>DevOps</option>
                        <option @(selectedCategory == "Segurança" ? "selected" : "")>Segurança</option>
                        <option @(selectedCategory == "Liderança" ? "selected" : "")>Liderança</option>
                        <option @(selectedCategory == "Comunicação" ? "selected" : "")>Comunicação</option>
                        <option @(selectedCategory == "Debugging" ? "selected" : "")>Debugging</option>
                        <option @(selectedCategory == "Performance" ? "selected" : "")>Performance</option>
                        <option @(selectedCategory == "Legado" ? "selected" : "")>Legado</option>
                    </select>
                </label>
            </div>

            <div class="challenge-builder-block">
                <div>
                    <strong>1. Descrição do problema</strong>
                    <span>Contexto, impacto, restrições, pressão e decisão esperada do candidato.</span>
                </div>
                <textarea name="Scenario" rows="8" data-community-text placeholder="Ex: Em produção, um endpoint MVC começou a responder acima de 8s no pico. O time precisa reduzir impacto sem reescrever o sistema. Explique o cenário, logs disponíveis, restrições e o que o dev precisa decidir.">@Model.Scenario</textarea>
            </div>

            <div class="challenge-builder-block">
                <div>
                    <strong>2. Código do desafio</strong>
                    <span>Trecho base que o dev deve analisar, refatorar, depurar ou explicar.</span>
                </div>
                <textarea class="code-input" name="CodeSnippet" rows="10" data-community-text spellcheck="false" placeholder="public ActionResult Orders()&#10;{&#10;    var customers = db.Customers.ToList();&#10;    foreach (var customer in customers)&#10;    {&#10;        customer.LastOrder = db.Orders.Where(o => o.CustomerId == customer.Id).FirstOrDefault();&#10;    }&#10;    return View(customers);&#10;}">@Model.CodeSnippet</textarea>
            </div>

            <div class="challenge-builder-block">
                <div>
                    <strong>3. Resposta esperada</strong>
                    <span>Critérios de avaliação, trade-offs aceitáveis e sinais de maturidade técnica.</span>
                </div>
                <textarea name="ExpectedAnswer" rows="7" data-community-text placeholder="Ex: Deve identificar N+1, propor consulta agregada ou projeção, medir antes/depois, evitar overengineering e explicar impacto em produção.">@Model.ExpectedAnswer</textarea>
            </div>

            <div class="anti-spam-strip">
                <span>Cooldown ativo</span>
                <span>@Model.DailyLimitRemaining envios restantes hoje</span>
                <span>Rep mínima: @Model.MinimumReputationRequired</span>
            </div>

            <button class="btn btn-primary" type="submit">Enviar para revisão</button>
        </div>

        <aside class="community-panel quality-preview">
            <span class="eyebrow">Quality gate fake</span>
            <h2>O que será avaliado</h2>
            <div class="quality-rule"><strong>Clareza</strong><span>Cenário compreensível e sem ambiguidade.</span></div>
            <div class="quality-rule"><strong>Código-base</strong><span>Trecho suficiente para simular trabalho real.</span></div>
            <div class="quality-rule"><strong>Relevância</strong><span>Problema real de engenharia, não trivia.</span></div>
            <div class="quality-rule"><strong>Dificuldade</strong><span>Atrito adequado para o nível técnico.</span></div>
            <div class="quality-rule"><strong>Anti-genérico</strong><span>Bloqueia respostas curtas, vagas ou copiadas.</span></div>
            <div class="quality-rule"><strong>Sem IA paga agora</strong><span>A avaliação usa heurística local e homologação comunitária.</span></div>
            <div class="quality-meter"><span data-community-score style="width:42%"></span></div>
            <small data-community-score-label>Score estimado: 42</small>
        </aside>
    </form>
</section>
